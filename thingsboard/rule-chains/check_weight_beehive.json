      {
        "type": "org.thingsboard.rule.engine.filter.TbJsFilterNode",
        "name": "calculate_weight-stabilty",
        "debugSettings": null,
        "singletonMode": false,
        "queueName": null,
        "configurationVersion": 0,
        "configuration": {
          "scriptLang": "JS",
          "jsScript": "var data = JSON.parse(metadata.weight);\r\n/* calculate slope (linear regression) */\r\nvar n = data.length;\r\nvar sumX=0, sumY=0, sumXY=0, sumX2=0;\r\n\r\nfor (var i=0; i<n; i++) {\r\n    var x = data[i].ts / (1000 * 60 * 60); // time in hours\r\n    var y = data[i].value;\r\n    sumX += x; sumY += y; sumXY += x*y; sumX2 += x*x;\r\n}\r\n\r\nvar slope = (n*sumXY - sumX*sumY) / (n*sumX2 - sumX*sumX);\r\n\r\n/* if the slop is close to 0 it \r\nmeans that the weight is stable */\r\nreturn Math.abs(slope) < 0.05; // 0.01 kg/h is the threshold\r\n",
          "tbelScript": "return msg.temperature > 20;"
        },
        "additionalInfo": {
          "description": "Calculate if the weight is stable during the selected days",
          "layoutX": 635,
          "layoutY": 157
        }
      },
