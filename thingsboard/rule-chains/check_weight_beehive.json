      {
        "type": "org.thingsboard.rule.engine.metadata.TbGetTelemetryNode",
        "name": "get_weight-timeseries",
        "debugSettings": null,
        "singletonMode": false,
        "queueName": null,
        "configurationVersion": 2,
        "configuration": {
          "latestTsKeyNames": [
            "weight"
          ],
          "aggregation": "NONE",
          "fetchMode": "FIRST",
          "orderBy": "ASC",
          "limit": 1000,
          "useMetadataIntervalPatterns": false,
